# =============================================================================
# Auth Service — Environment Variables Template
# =============================================================================
# Copy to .env and fill in secrets before running locally or with Docker.
# =============================================================================

# Server
PORT=8080
GIN_MODE=debug

# PostgreSQL (local dev — points to localhost)
# Must match the credentials in docker-compose.yml postgres service.
POSTGRES_DB=auth_db
POSTGRES_USER=auth_app
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL=postgresql://auth_app:your_postgres_password@localhost:5432/auth_db?sslmode=disable

# Redis (local dev — points to localhost)
REDIS_URL=redis://localhost:6379

# JWT / RSA Keys
PRIVATE_KEY_PATH=./keys/private.pem
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h

# Google OAuth (required — never commit real values to source control)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret